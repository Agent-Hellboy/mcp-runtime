# Keep the builder on a patched Go 1.25.x toolchain so the shipped operator
# binary is built without the stdlib CVEs flagged by Trivy.
FROM golang:1.25.8-alpine3.23 AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o manager ./cmd/operator

FROM alpine:3.23

RUN apk --no-cache upgrade && apk --no-cache add ca-certificates tzdata

WORKDIR /

COPY --from=builder /build/manager /manager

ENTRYPOINT ["/manager"]
