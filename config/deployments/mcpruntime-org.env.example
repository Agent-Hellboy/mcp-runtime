# MCP Runtime — k3s public deployment (mcpruntime.org)
#
# Copy to mcpruntime-org.env (same directory) and adjust paths or email if needed.
# mcpruntime-org.env is gitignored; keep secrets out of the example file.
#
# Full variable reference:
#   docs/k3s-deployment-runbook.md#environment-variable-reference
#
# Usage:
#   hack/deploy/mcpruntime-org/setup.sh
#   hack/deploy/mcpruntime-org/clean.sh --yes --wait
#   hack/deploy/mcpruntime-org/restore.sh
#   hack/deploy/mcpruntime-org/rollout.sh
#
# Override profile path: MCP_DEPLOY_ENV=/path/to/other.env

# --- Cluster access ---
export KUBECONFIG=/private/tmp/mcpruntime-k3s.yaml

# --- Public platform hostnames (registry / mcp / platform are derived) ---
export MCP_PLATFORM_DOMAIN=mcpruntime.org

# Workstation builds linux images; k3s nodes on this cluster are amd64.
export MCP_IMAGE_PLATFORM=linux/amd64

# Required for non-test-mode setup validation (platform admin bootstrap).
export MCP_PLATFORM_ADMIN_EMAIL=admin@example.com

# --- Setup timing ---
export MCP_SETUP_WAIT_TIMEOUT=900
# MCP_CERT_TIMEOUT=15m   # optional; first install only — extends cert-manager wait

# --- Registry (bundled-https) ---
# Pod pulls MUST use the TLS-covered hostname — NOT the registry Service ClusterIP.
export MCP_REGISTRY_ENDPOINT=registry.mcpruntime.org
# MCP_REGISTRY_INGRESS_HOST=registry.mcpruntime.org   # optional; derived from MCP_PLATFORM_DOMAIN
# MCP_REGISTRY_HOST=...                               # do not use as a pull URL; public ingress alias only
# MCP_REGISTRY_INTERNAL=10.x.x.x:5000                 # optional; rollout build/push override only

# Do NOT set on reruns:
# MCP_ACME_EMAIL=...                                  # use MCP_SETUP_TLS_CLUSTER_ISSUER instead

# --- Setup script flags (read by hack/deploy/mcpruntime-org/setup.sh) ---
export MCP_SETUP_KUBECONFIG="${KUBECONFIG}"
export MCP_SETUP_PLATFORM_MODE=tenant
export MCP_SETUP_REGISTRY_MODE=bundled-https
export MCP_SETUP_INGRESS=none
export MCP_SETUP_TLS_CLUSTER_ISSUER=letsencrypt-prod
export MCP_SETUP_SKIP_CERT_MANAGER_INSTALL=1

# k3s uses kube-system Traefik; do not patch repo-managed traefik/traefik on team create.
export PLATFORM_TEAM_TRAEFIK_WATCH=disabled
export PLATFORM_TRAEFIK_NAMESPACE=kube-system

# --- Platform-runtime backup (hack/deploy/mcpruntime-org/clean.sh) ---
# Preserves TLS, OIDC, bootstrap secrets across clean+setup. NOT tenant/user data.
# export MCP_TLS_BACKUP_DIR="$HOME/.mcpruntime/backups/mcpruntime-org"
# export MCP_RESTORE_TLS_AFTER_SETUP=1

# --- Browser sign-in (required for public/tenant UI on setup) ---
# export GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# export MCP_GOOGLE_CLIENT_ID=...        # optional alias
# export OIDC_ISSUER=...                 # optional non-Google provider
# export OIDC_AUDIENCE=...
# export OIDC_JWKS_URL=...

# --- Rollout-only (hack/deploy/mcpruntime-org/rollout.sh) ---
# export MCP_ROLLOUT_TAG=verify-05252230

# --- Multitenancy test (hack/deploy/mcpruntime-org/multitenancy-test.sh — export at test time, not here) ---
# PLATFORM_URL=https://platform.mcpruntime.org
# MCP_URL=https://mcp.mcpruntime.org
# REGISTRY_HOST=registry.mcpruntime.org
