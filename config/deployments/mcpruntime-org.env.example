# MCP Runtime — k3s public deployment (mcpruntime.org)
#
# Copy to mcpruntime-org.env (same directory) and fill in real values.
# mcpruntime-org.env is gitignored; keep secrets out of this file.
#
# All variables below map 1-to-1 to a `mcp-runtime setup` flag so that
# the full setup can be driven with just:
#
#   bin/mcp-runtime setup --env-file config/deployments/mcpruntime-org.env
#
# Full variable reference: docs/k3s-deployment-runbook.md#environment-variable-reference
#
# Other scripts that consume this file:
#   hack/deploy/mcpruntime-org/setup.sh
#   hack/deploy/mcpruntime-org/clean.sh --yes --wait
#   hack/deploy/mcpruntime-org/restore.sh
#   hack/deploy/mcpruntime-org/rollout.sh
#
# Override profile path: MCP_DEPLOY_ENV=/path/to/other.env

# ---------------------------------------------------------------------------
# Cluster access  (--kubeconfig / --context)
# ---------------------------------------------------------------------------
export MCP_SETUP_KUBECONFIG=/private/tmp/mcpruntime-k3s.yaml
# export MCP_KUBE_CONTEXT=             # optional; selects a named kubeconfig context

# ---------------------------------------------------------------------------
# Public platform hostnames
# registry.<domain>, mcp.<domain>, platform.<domain> are derived automatically.
# ---------------------------------------------------------------------------
export MCP_PLATFORM_DOMAIN=mcpruntime.org

# Internal pod pulls MUST use the TLS-covered registry hostname (not a ClusterIP).
export MCP_REGISTRY_ENDPOINT=registry.mcpruntime.org
# export MCP_REGISTRY_INGRESS_HOST=registry.mcpruntime.org   # optional; derived from MCP_PLATFORM_DOMAIN

# Workstation builds Linux images; k3s nodes on this cluster are amd64.
export MCP_IMAGE_PLATFORM=linux/amd64

# Required for non-test-mode setup validation (platform admin bootstrap).
export MCP_PLATFORM_ADMIN_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Registry  (--registry-mode / --registry-type / --registry-storage)
# ---------------------------------------------------------------------------
export MCP_SETUP_REGISTRY_MODE=bundled-https   # auto | bundled-http | bundled-https | external
# export MCP_REGISTRY_TYPE=docker              # docker (default); harbor coming soon
# export MCP_REGISTRY_STORAGE_SIZE=20Gi        # default: 20Gi

# External/provisioned registry — only needed for --registry-mode external
# export PROVISIONED_REGISTRY_URL=
# export PROVISIONED_REGISTRY_USERNAME=
# export PROVISIONED_REGISTRY_PASSWORD=

# ---------------------------------------------------------------------------
# Storage  (--storage-mode)
# ---------------------------------------------------------------------------
# export MCP_STORAGE_MODE=dynamic   # dynamic (default) | hostpath (single-node k3s/minikube/kind)

# ---------------------------------------------------------------------------
# Platform mode  (--platform-mode)
# ---------------------------------------------------------------------------
export MCP_SETUP_PLATFORM_MODE=tenant   # tenant (default) | org | public

# ---------------------------------------------------------------------------
# Ingress  (--ingress / --ingress-manifest / --force-ingress-install)
# ---------------------------------------------------------------------------
export MCP_SETUP_INGRESS=none           # traefik (default) | none
# export MCP_SETUP_INGRESS_MANIFEST=    # path to kustomize overlay; default derives from --with-tls
# export MCP_FORCE_INGRESS_INSTALL=1    # force repo-managed ingress even when IngressClass exists

# ---------------------------------------------------------------------------
# TLS  (--with-tls / --tls-cluster-issuer / --acme-email / --skip-cert-manager-install)
# ---------------------------------------------------------------------------
export MCP_SETUP_WITH_TLS=1
export MCP_SETUP_TLS_CLUSTER_ISSUER=letsencrypt-prod   # pre-existing ClusterIssuer; mutually exclusive with MCP_ACME_EMAIL
# Separate enterprise issuer for workload mTLS; do not use Let's Encrypt here.
# export MCP_SETUP_MTLS_CLUSTER_ISSUER=company-workload-ca
# export MCP_ACME_EMAIL=                                # Let's Encrypt contact; mutually exclusive with MCP_SETUP_TLS_CLUSTER_ISSUER
# export MCP_ACME_STAGING=1                             # use Let's Encrypt staging CA
export MCP_SETUP_SKIP_CERT_MANAGER_INSTALL=1            # set when cert-manager is already installed

# ---------------------------------------------------------------------------
# Deployment behaviour  (--test-mode / --without-sentinel / --parallel-builds / --strict-prod)
# ---------------------------------------------------------------------------
# export MCP_SETUP_TEST_MODE=1        # local Kind/dev only — builds and pushes runtime images
# export MCP_WITHOUT_SENTINEL=1       # skip deploying the mcp-sentinel analytics stack
# export MCP_PARALLEL_BUILDS=1        # build setup images in parallel
# export MCP_STRICT_PROD=1            # require production-style registry + TLS validation

# ---------------------------------------------------------------------------
# Setup timing
# ---------------------------------------------------------------------------
export MCP_SETUP_WAIT_TIMEOUT=900
# export MCP_CERT_TIMEOUT=15m         # optional; extend cert-manager wait on first install

# ---------------------------------------------------------------------------
# Browser sign-in (required for public/tenant UI OIDC on setup)
# ---------------------------------------------------------------------------
# export GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# export MCP_GOOGLE_CLIENT_ID=...     # optional alias
# export OIDC_ISSUER=...              # optional non-Google provider
# export OIDC_AUDIENCE=...
# export OIDC_JWKS_URL=...

# ---------------------------------------------------------------------------
# k3s-specific: use kube-system Traefik; do not patch repo-managed traefik
# ---------------------------------------------------------------------------
export PLATFORM_TEAM_TRAEFIK_WATCH=disabled
export PLATFORM_TRAEFIK_NAMESPACE=kube-system

# ---------------------------------------------------------------------------
# Platform-runtime backup (hack/deploy/mcpruntime-org/clean.sh)
# Preserves TLS, OIDC, bootstrap secrets across clean+setup. NOT tenant/user data.
# ---------------------------------------------------------------------------
# export MCP_TLS_BACKUP_DIR="$HOME/.mcpruntime/backups/mcpruntime-org"
# export MCP_RESTORE_TLS_AFTER_SETUP=1

# ---------------------------------------------------------------------------
# Rollout-only (hack/deploy/mcpruntime-org/rollout.sh)
# ---------------------------------------------------------------------------
# export MCP_ROLLOUT_TAG=verify-05252230

# ---------------------------------------------------------------------------
# Multitenancy test (hack/deploy/mcpruntime-org/multitenancy-test.sh — export at test time, not here)
# ---------------------------------------------------------------------------
# PLATFORM_URL=https://platform.mcpruntime.org
# MCP_URL=https://mcp.mcpruntime.org
# REGISTRY_HOST=registry.mcpruntime.org
